# ─── Telegram ───────────────────────────────────────────────
BOT_TOKEN=                      # токен бота от @BotFather
SOCKS_PROXY=                    # (опц.) socks5://user:pass@host:port, если нужен прокси
ADMIN_CHAT_ID=                  # chat_id для фолбэк-уведомлений
GROUP_CHAT_ID=                  # ID группы с темами по вакансиям

# ─── База данных (PostgreSQL) ───────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# ─── Google ─────────────────────────────────────────────────
GOOGLE_CREDENTIALS_PATH=./google-credentials.json   # сервисный аккаунт
GOOGLE_SHEETS_ID_USERS=                 # таблица пользователей
GOOGLE_SHEETS_RANGE_USERS=Лист1!A:D
GOOGLE_SHEETS_ID_VACANCIES=             # таблица со списком вакансий
GOOGLE_SHEETS_RANGE_VACANCIES=A:D
GOOGLE_SHEETS_ID_CALENDAR=              # таблица-календарь собеседований
GOOGLE_SHEETS_RANGE_CALENDAR=сводная таблица кандидатов (копия)!A:H

# ─── HH.ru OAuth2 ───────────────────────────────────────────
HH_CLIENT_ID=
HH_CLIENT_SECRET=
HH_REDIRECT_URI=                # напр. https://yourdomain/hh-ru/callback
OAUTH_PORT=3000                 # порт локального OAuth-сервера
HH_USER_AGENT=hr-tg-bot/1.0 (you@example.com)

# ─── ИИ (OpenAI-совместимый endpoint) ───────────────────────
AI_ENDPOINT=http://localhost:18789/v1/responses
AI_TOKEN=
AI_MODEL=

# ─── Флаги поведения ────────────────────────────────────────
USE_LOCAL_PROCESSING=true       # обрабатывать локально (не через внешний webhook)
HHRU_DRY_RUN=false              # true = не выполнять действия на HH (только анализ)
QUESTIONNAIRE_HH_ACTIONS=true   # включить действия по анкетам (по «Действие HR»)
ANKETA_HR_DRY_RUN=false         # true = только логировать решения по анкетам
CHAT_ROUTER_DRY_RUN=false       # true = роутер чатов только логирует, ничего не шлёт
SCHEDULER_TZ=Europe/Moscow      # часовой пояс планировщика

# ─── (опц.) внешние вебхуки, если используется n8n ──────────
N8N_WEBHOOK_HHRU=
N8N_WEBHOOK_QUESTIONNAIRE=
